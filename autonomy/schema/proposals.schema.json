{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://codex-auto.local/schema/proposals.schema.json",
  "title": "AutonomyProposalsFile",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "proposals"
  ],
  "properties": {
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "proposals": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/proposal"
      },
      "default": []
    }
  },
  "$defs": {
    "proposedTask": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "title",
        "priority",
        "depends_on",
        "acceptance",
        "file_hints"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "priority": {
          "type": "string",
          "enum": [
            "P0",
            "P1",
            "P2",
            "P3"
          ]
        },
        "depends_on": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true,
          "default": []
        },
        "acceptance": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "default": []
        },
        "file_hints": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "default": []
        }
      }
    },
    "proposal": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "goal_id",
        "status",
        "summary",
        "tasks",
        "created_at",
        "approved_at"
      ],
      "properties": {
        "goal_id": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "type": "string",
          "enum": [
            "awaiting_confirmation",
            "approved",
            "superseded",
            "cancelled"
          ]
        },
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "tasks": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/proposedTask"
          }
        },
        "created_at": {
          "type": "string",
          "format": "date-time"
        },
        "approved_at": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time"
        }
      }
    }
  }
}
